# Copy this file to `.env` and fill in real values. `.env` is gitignored.
HOST=0.0.0.0
PORT=8000
ALLOWED_ORIGINS=http://localhost:3000

# Optional: enables GPT-4o personalized styling explanations.
# Leave blank to run the app without the LLM (falls back to static descriptions).
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o